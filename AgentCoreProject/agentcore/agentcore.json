      "name": "CustomerAssistantAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/CustomerAssistantAgent/",
      "runtimeVersion": "PYTHON_3_13",
      "envVars": [
        {
          "name": "AGENTCORE_MEMORY_ID",
          "value": "AgentCoreProject_CustomerAssistantMemory-uSssY39Qey"
        },
        {
          "name": "AWS_REGION",
          "value": "us-west-2"
        },
        {
          "name": "GATEWAY_URL",
          "value": "https://agentcoreproject-workshop-gateway-h1mwj05fpt.gateway.bedrock-agentcore.us-west-2.amazonaws.com/mcp"
        },
        {
          "name": "GATEWAY_CLIENT_ID",
          "value": "5m7o8sdrchcgf79rugsvo7one3"
        },
        {
          "name": "GATEWAY_CLIENT_SECRET",
          "value": "1ke3s4cevs3hqt4ccndsm5guqv9iihij5i76u7j7uopc1rj9e20d"
        },
        {
          "name": "GATEWAY_TOKEN_ENDPOINT",
          "value": "https://workshop-gateway-1778786228.auth.us-west-2.amazoncognito.com/oauth2/token"
        },
        {
          "name": "GATEWAY_SCOPE",
          "value": "gateway-api/invoke"
        }
      ],
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [
    {
      "name": "CustomerAssistantMemory",
      "eventExpiryDuration": 7,
      "strategies": [
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaces": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "SEMANTIC",
          "namespaces": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaces": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaces": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "credentials": [
    {
      "authorizerType": "OAuthCredentialProvider",
      "name": "workshop-gateway-oauth",
      "discoveryUrl": "https://cognito-idp.us-west-2.amazonaws.com/us-west-2_33qNjxBq9/.well-known/openid-configuration",
      "vendor": "CustomOauth2",
      "managed": true,
      "usage": "inbound"
    }
  ],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "workshop-gateway",
      "description": "Gateway for workshop-gateway",
      "targets": [
        {
          "name": "data-lookup",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-west-2:755547689151:function:returns-refunds-data-lookup",
            "toolSchemaFile": "./tool_specs/data_lookup.json"
          }
        },
        {
          "name": "policy-retrieval",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-west-2:755547689151:function:returns-refunds-policy-retrieval",
            "toolSchemaFile": "./tool_specs/policy_retrieval.json"
          }
        }
      ],
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "https://cognito-idp.us-west-2.amazonaws.com/us-west-2_33qNjxBq9/.well-known/openid-configuration",
          "allowedClients": [
            "5m7o8sdrchcgf79rugsvo7one3"
          ]
        }
      },
      "enableSemanticSearch": true,
