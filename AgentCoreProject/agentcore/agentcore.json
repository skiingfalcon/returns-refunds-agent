{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "AgentCoreProject",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "AgentCoreProject"
  },
  "runtimes": [
    {
      "name": "CustomerAssistantAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/CustomerAssistantAgent/",
      "runtimeVersion": "PYTHON_3_13",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "envVars": [
        {
          "name": "AGENTCORE_MEMORY_ID",
          "value": "AgentCoreProject_CustomerAssistantMemory-uSssY39Qey"
        },
        {
          "name": "AWS_REGION",
          "value": "us-west-2"
        }
      ],
      "memories": [
        "CustomerAssistantMemory"
      ]
    }
  ],
  "memories": [
    {
      "name": "CustomerAssistantMemory",
      "eventExpiryDuration": 7,
      "strategies": [
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaces": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "SEMANTIC",
          "namespaces": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaces": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaces": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": []
}